@import Foundation;
@import Security;
id provider = [[IDSRegistrationKeyManager sharedInstance] keyPairProvider];
SecKeyRef *pubp = (SecKeyRef *)malloc(sizeof(SecKeyRef));
SecKeyRef *privp = (SecKeyRef *)malloc(sizeof(SecKeyRef));
