BOOL *upp = (BOOL *)malloc(sizeof(BOOL));
*pubp = NULL; *privp = NULL; *sigp = nil; *migp = NO; *upp = NO;
BOOL ok = [(id)provider copyRegistrationKeyPairForIdentifier:@"D:19478336641" publicKey:pubp privateKey:privp keyPairSignature:sigp isMigratedSignature:migp isUpgradePending:upp];
ok
