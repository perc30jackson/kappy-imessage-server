# Line 3 — copy to poc/lines/line-3.env and fill in credentials.
#
# State dir: isolated tree for line 3 (do not point at spike/state — that is line 1).
# Created automatically by poc-init-line.sh / poc-line.sh.

export KAPPY_SPIKE_STATE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lines/line-3/state"

# Dedicated Apple ID for line 3 (SMS-verified; not line 1 or line 2).
export KAPPY_APPLE_ID=you-line3@icloud.com
export KAPPY_APPLE_PASSWORD=
