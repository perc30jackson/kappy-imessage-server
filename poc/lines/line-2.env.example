# Line 2 — copy to poc/lines/line-2.env and fill in credentials.
#
# State dir: isolated tree for line 2 (do not point at spike/state — that is line 1).
# Created automatically by poc-init-line.sh / poc-line.sh.

export KAPPY_SPIKE_STATE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lines/line-2/state"

# Dedicated Apple ID for line 2 (SMS-verified; not the line 1 account).
export KAPPY_APPLE_ID="worker@jabronicapital.com"
export KAPPY_APPLE_PASSWORD=""

# Optional: Telnyx SMS REG (see spike sms-reg-send). Do not commit real keys.
# export TELNYX_API_KEY=""
# export TELNYX_FROM_NUMBER="+1..."
# export KAPPY_SMS_MCCMNC="310260"
# export TELNYX_MESSAGING_PROFILE_ID=""
