# Shared PoC config (copy to poc/shared.env and fill in)

# Validation: lldb (macOS 26 PoC Mac) | nacserv (helper VM)
export KAPPY_VALIDATION_MODE=lldb

# Path to kappy-spike binary
export KAPPY_SPIKE_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/target/release/kappy-spike"

# Helper VM nacserv (fallback when VM is up)
export KAPPY_NACSERV_URL=http://192.168.64.3:8788
export KAPPY_NACSERV_TOKEN=

# Shared hardware export (Mac Hardware Info app → save here)
export KAPPY_HW_EXPORT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/shared/hw-export.bin"

export RUST_LOG="${RUST_LOG:-rustpush::ids::user=info,kappy_spike=info}"
